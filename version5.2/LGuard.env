# ============================================================
# L-GUARD v5.4 - ENVIRONMENT CONFIGURATION FILE
# ============================================================
# Copy this file and rename it to ".env" in your project root
# Modify the values according to your setup
# NEVER commit this file to version control (add to .gitignore)
# ============================================================

# ==================== DEVICE IDENTIFICATION ====================
# Unique identifier for this vehicle/device
# Use format: VEHICLE_XXX or any unique name
DEVICE_ID=VEHICLE_001

# Alternative naming examples:
# DEVICE_ID=TAXI_KGL_001
# DEVICE_ID=TRUCK_FLEET_A_025
# DEVICE_ID=PERSONAL_CAR_JOHN

# ==================== EMERGENCY CONTACT ====================
# Phone number to receive SMS alerts (include country code)
# Format: +[country_code][phone_number]
EMERGENCY_CONTACT=+2507929577181

# Multiple contacts (if you want to modify code to support):
# EMERGENCY_CONTACT_1=+2507929577181
# EMERGENCY_CONTACT_2=+250788123456
# EMERGENCY_CONTACT_3=+250722334455

# ==================== CELLULAR NETWORK ====================
# Access Point Name (APN) for your mobile carrier
# Check with your carrier for correct APN

# Rwanda - MTN
APN=internet.mtn.rw

# Rwanda - Airtel (alternative)
# APN=internet

# Other carriers - replace with your APN:
# Kenya - Safaricom: internet
# Uganda - MTN: internet
# Tanzania - Vodacom: internet
# USA - T-Mobile: fast.t-mobile.com
# USA - AT&T: broadband

# ==================== API CONFIGURATION ====================
# Backend server endpoint for telemetry data
API_URL=https://lguard-backend-service.onrender.com/api/v1/telemetry/ingest

# Alternative endpoints (if you have multiple environments):
# API_URL_PRODUCTION=https://lguard-backend-service.onrender.com/api/v1/telemetry/ingest
# API_URL_STAGING=https://lguard-staging.onrender.com/api/v1/telemetry/ingest
# API_URL_DEVELOPMENT=http://192.168.1.100:3000/api/v1/telemetry/ingest

# API Authentication (if your backend requires it)
# API_KEY=your_api_key_here
# API_SECRET=your_api_secret_here

# ==================== SPEED ALERT SETTINGS ====================
# Speed limit threshold (km/h)
# Buzzer will beep when this speed is exceeded
SPEED_LIMIT=60

# Minimum satellites required for speed detection
# Higher = more accurate but may not work in poor conditions
# Recommended: 4-6
MIN_SATELLITES_FOR_SPEED=5

# Minimum GPS accuracy (HDOP threshold)
# Lower = better accuracy (1.0 = perfect, 2.5 = good)
# Speed alerts won't trigger if HDOP is above this value
MIN_GPS_HDOP=2.5

# Minimum speed threshold (km/h)
# Speeds below this are considered GPS noise/drift
# Recommended: 5.0
MIN_SPEED_THRESHOLD=5.0

# ==================== IMPACT DETECTION THRESHOLDS ====================
# All values in g-force (1g = 9.8 m/s²)

# Low impact threshold (monitoring only, no alert)
ADXL345_LOW_THRESHOLD=3.0

# Medium impact threshold (triggers medium severity alert)
ADXL345_MEDIUM_THRESHOLD=8.0

# High impact threshold (triggers high severity alert)
ADXL345_HIGH_THRESHOLD=15.0

# Increase these values if getting false positives:
# ADXL345_MEDIUM_THRESHOLD=10.0
# ADXL345_HIGH_THRESHOLD=18.0

# ==================== ROLLOVER DETECTION ====================
# Tilt angle warning threshold (degrees)
# Vehicle is tilted but not rolled over
MPU6050_TILT_THRESHOLD=45.0

# Rollover angle threshold (degrees)
# Vehicle is on its side or upside down
MPU6050_ROLLOVER_THRESHOLD=70.0

# Gyroscope rotation threshold (rad/s)
# Detects rapid spinning/flipping
GYRO_ROTATION_THRESHOLD=3.0

# Rollover stability count
# Number of consecutive readings needed to confirm rollover
# Prevents false positives from bumps
ROLLOVER_STABILITY_COUNT=3

# ==================== SPEED DROP DETECTION ====================
# Sudden speed drop threshold (km/h)
# Detects rapid deceleration (crash stop)
SPEED_DROP_THRESHOLD=30.0

# ==================== TIMING CONFIGURATION ====================
# All values in milliseconds

# GPS warm-up time (delay before enabling speed alerts)
# Prevents false alarms on startup
GPS_WARMUP_TIME=10000

# Accident cancellation window (time to press cancel button)
CANCEL_WINDOW=10000

# Data sync check interval (check for changes)
API_SYNC_INTERVAL=30000

# Force sync interval (heartbeat - send even if no changes)
API_FORCE_SYNC_INTERVAL=300000

# Sleep mode idle time (enter sleep after this long with no activity)
SLEEP_IDLE_TIME=120000

# Status print interval (how often to print to Serial)
STATUS_PRINT_INTERVAL=5000

# Speed beep interval (how often buzzer beeps when speeding)
SPEED_BEEP_INTERVAL=1000

# ==================== CHANGE DETECTION THRESHOLDS ====================
# Determines when data is significant enough to send to API

# Speed change threshold (km/h)
# Send data if speed changes by this amount
SPEED_CHANGE_THRESHOLD=10.0

# Location change threshold (decimal degrees)
# Approximately 11 meters at equator
LOCATION_CHANGE_THRESHOLD=0.0002

# Acceleration change threshold (g-force)
ACCEL_CHANGE_THRESHOLD=2.0

# Angle change threshold (degrees)
ANGLE_CHANGE_THRESHOLD=30.0

# Battery change threshold (percent)
# Send data if battery changes by this percentage
BATTERY_CHANGE_THRESHOLD=10

# ==================== BATTERY MONITOR ====================
# Battery voltage thresholds (LiPo battery)

# Minimum voltage (empty battery)
BATTERY_MIN_VOLTAGE=3.3

# Maximum voltage (fully charged)
BATTERY_MAX_VOLTAGE=4.2

# Voltage divider ratio (hardware dependent)
# If using 10kΩ + 10kΩ resistors: 2.0
BATTERY_DIVIDER=2.0

# ==================== I2C CONFIGURATION ====================
# I2C bus pins for ESP32

# I2C SDA pin (data)
I2C_SDA_PIN=21

# I2C SCL pin (clock)
I2C_SCL_PIN=22

# MPU6050 I2C address
# CRITICAL: Set AD0 pin to GND for address 0x69
MPU6050_ADDRESS=0x69

# ADXL345 I2C address (default)
ADXL345_ADDRESS=0x53

# ==================== PIN DEFINITIONS ====================
# ESP32 GPIO pin assignments

# Modem pins
MODEM_RI_PIN=2
MODEM_TXD=4
MODEM_RXD=5
MODEM_PWR_PIN=15
MODEM_DTR_PIN=18
MODEM_RESET_PIN=19

# GPS pins
GPS_MODULE_TX=16
GPS_MODULE_RX=17

# Control pins
BUZZER_PIN=25
OK_BUTTON_PIN=26
MENU_BUTTON_PIN=27

# Sensor pins
VIBRATION_DIGITAL_PIN=32
BIKE_MONITOR_PIN=33
BATTERY_ADC_PIN=34

# LED pins
SAFE_LED_PIN=25
DANGER_LED_PIN=14
GPS_LED_PIN=13
GSM_LED_PIN=23
SYSTEM_LED_PIN=-1

# ==================== SERIAL CONFIGURATION ====================
# Serial baud rates

# Debug serial (USB)
SERIAL_BAUD=115200

# GPS serial baud rate
GPS_BAUD=9600

# Modem serial baud rate
MODEM_BAUD=115200

# ==================== FEATURE FLAGS ====================
# Enable/disable specific features

# Enable sleep mode (1=enabled, 0=disabled)
ENABLE_SLEEP_MODE=1

# Enable speed alerts (1=enabled, 0=disabled)
ENABLE_SPEED_ALERTS=1

# Enable accident detection (1=enabled, 0=disabled)
ENABLE_ACCIDENT_DETECTION=1

# Enable API sync (1=enabled, 0=disabled)
ENABLE_API_SYNC=1

# Enable SMS alerts (1=enabled, 0=disabled)
ENABLE_SMS_ALERTS=1

# Enable smart data sync (1=enabled, 0=disabled)
# If disabled, sends every API_SYNC_INTERVAL regardless of changes
ENABLE_SMART_SYNC=1

# Enable debug output to Serial (1=enabled, 0=disabled)
ENABLE_DEBUG_OUTPUT=1

# ==================== ADVANCED SETTINGS ====================
# Only modify if you know what you're doing

# ADXL345 range setting (2G, 4G, 8G, 16G)
# Higher = can detect stronger impacts but less precise
ADXL345_RANGE=16

# ADXL345 data rate (Hz)
ADXL345_DATA_RATE=400

# MPU6050 accelerometer range (2G, 4G, 8G, 16G)
MPU6050_ACCEL_RANGE=8

# MPU6050 gyroscope range (250, 500, 1000, 2000 deg/s)
MPU6050_GYRO_RANGE=500

# MPU6050 filter bandwidth (5, 10, 21, 44, 94, 184, 260 Hz)
MPU6050_FILTER_BANDWIDTH=21

# HTTP request timeout (milliseconds)
HTTP_TIMEOUT=30000

# SMS send timeout (milliseconds)
SMS_TIMEOUT=10000

# ==================== NOTES ====================
# 1. Always restart device after changing .env values
# 2. Test thoroughly after any configuration change
# 3. Keep backup of working configuration
# 4. Document any custom changes you make
# 5. Check Serial Monitor for configuration confirmation

# ==================== EXAMPLES FOR DIFFERENT SCENARIOS ====================

# EXAMPLE 1: Motorcycle/Bike (more sensitive)
# ADXL345_MEDIUM_THRESHOLD=5.0
# ADXL345_HIGH_THRESHOLD=10.0
# SPEED_LIMIT=50

# EXAMPLE 2: Heavy Truck (less sensitive)
# ADXL345_MEDIUM_THRESHOLD=12.0
# ADXL345_HIGH_THRESHOLD=20.0
# SPEED_LIMIT=80

# EXAMPLE 3: Racing/Track Vehicle (high speeds, less sensitive)
# SPEED_LIMIT=120
# ADXL345_HIGH_THRESHOLD=25.0
# ENABLE_SPEED_ALERTS=0

# EXAMPLE 4: Taxi/Fleet (maximum monitoring)
# ENABLE_SMART_SYNC=0
# API_SYNC_INTERVAL=10000
# SPEED_LIMIT=50

# EXAMPLE 5: Development/Testing (verbose output)
# ENABLE_DEBUG_OUTPUT=1
# STATUS_PRINT_INTERVAL=1000
# ENABLE_SLEEP_MODE=0

# ============================================================
# END OF CONFIGURATION FILE
# ============================================================