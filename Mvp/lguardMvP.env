# ================================================================
# EMERGENCY CONTACT CONFIGURATION
# ================================================================

# Primary Emergency Contact (SMS recipient)
EMERGENCY_PHONE=+250795613644

# Additional Emergency Contacts (Optional)
# EMERGENCY_PHONE_2=+250788123456
# EMERGENCY_PHONE_3=+250722987654

# Emergency Contact Name (for SMS personalization)
EMERGENCY_CONTACT_NAME=Emergency Response Team


# ================================================================
# SENSOR THRESHOLDS - ACCIDENT DETECTION
# ================================================================

# Accelerometer Threshold (g-force)
# Default: 15.0 | Range: 10.0 - 25.0
# Lower = More sensitive | Higher = Less false alarms
ACCEL_THRESHOLD=15.0

# Gyroscope Threshold (rad/s)
# Default: 3.0 | Range: 2.0 - 5.0
# Detects vehicle rotation/rollover
GYRO_THRESHOLD=3.0

# Piezo Vibration Threshold (analog value)
# Default: 1200 | Range: 800 - 2000 (0-4095 scale)
# Detects impact/collision vibrations
PIEZO_THRESHOLD=1200


# ================================================================
# SPEED MONITORING THRESHOLDS
# ================================================================

# Overspeed Warning Threshold (km/h)
# Default: 40.0 | Buzzer activates above this speed
OVERSPEED_THRESHOLD=40.0

# Speed Drop Detection (km/h)
# Default: 30.0 | Minimum drop to trigger accident
SPEED_DROP_THRESHOLD=30.0

# Low Speed Threshold (km/h)
# Default: 10.0 | Speed must drop below this for accident
LOW_SPEED_THRESHOLD=10.0

# Minimum High Speed (km/h)
# Default: 40.0 | Speed must be above this before drop detection
MIN_HIGH_SPEED=40.0


# ================================================================
# TIMING CONFIGURATION
# ================================================================

# Cloud Data Sync Interval (milliseconds)
# Default: 30000 (30 seconds)
# Range: 10000 - 60000 (10s - 60s)
DATA_SEND_INTERVAL=30000

# Accident State Duration (milliseconds)
# Default: 30000 (30 seconds before auto-reset)
ACCIDENT_TIMEOUT=30000

# Overspeed Minimum Duration (seconds)
# Default: 5 (log only if overspeeding lasts 5+ seconds)
OVERSPEED_MIN_DURATION=5

# GPS Update Interval (milliseconds)
# Default: 1000 (1 second)
GPS_UPDATE_INTERVAL=1000

# GSM Check Interval (milliseconds)
# Default: 3000 (3 seconds)
GSM_CHECK_INTERVAL=3000


# ================================================================
# LED BLINK RATES (milliseconds)
# ================================================================

# Danger LED Blink Rate (accident detected)
DANGER_BLINK_RATE=200

# GPS LED - Fixed
GPS_BLINK_FIXED=500

# GPS LED - Searching
GPS_BLINK_SEARCHING=1000

# GSM LED - Connected
GSM_BLINK_CONNECTED=300

# GSM LED - Searching
GSM_BLINK_SEARCHING=1500

# WiFi LED - Connected
WIFI_BLINK_CONNECTED=1000

# WiFi LED - Config Mode
WIFI_BLINK_CONFIG=200

# WiFi LED - Disconnected
WIFI_BLINK_DISCONNECTED=2000

# Buzzer Beep Rate (overspeed)
BUZZER_BEEP_RATE=500


# ================================================================
# HARDWARE PIN CONFIGURATION
# ================================================================

# I2C Pins (MPU6050)
I2C_SDA_PIN=21
I2C_SCL_PIN=22

# GPS Serial Pins
GPS_RX_PIN=19
GPS_TX_PIN=18

# GSM Serial Pins
GSM_RX_PIN=16
GSM_TX_PIN=17

# Analog Sensor Pins
PIEZO_PIN=34

# LED Indicator Pins
SAFE_LED_PIN=2
DANGER_LED_PIN=4
GPS_LED_PIN=5
GSM_LED_PIN=25
WIFI_LED_PIN=27

# Buzzer Pin
BUZZER_PIN=26

# Configuration Button Pin
CONFIG_BUTTON_PIN=0


# ================================================================
# GPS CONFIGURATION
# ================================================================

# GPS Baud Rate
GPS_BAUD_RATE=9600

# GPS Module Type
# Options: NEO6M, NEO7M, NEO8M, GENERIC
GPS_MODULE_TYPE=NEO6M

# GPS Sentence Types to Parse
# Comma-separated: GPGGA,GPRMC,GPGSA,GPGSV
GPS_SENTENCES=GPGGA,GPRMC


# ================================================================
# GSM CONFIGURATION
# ================================================================

# GSM Baud Rate
GSM_BAUD_RATE=9600

# GSM Module Type
# Options: SIM800L, SIM900, SIM7600, GENERIC
GSM_MODULE_TYPE=SIM800L

# SMS Mode (1 = Text mode)
SMS_MODE=1

# Network Registration Timeout (seconds)
GSM_NETWORK_TIMEOUT=30


# ================================================================
# MPU6050 SENSOR CONFIGURATION
# ================================================================

# Accelerometer Range
# Options: 2G, 4G, 8G, 16G
ACCEL_RANGE=16G

# Gyroscope Range
# Options: 250, 500, 1000, 2000 (degrees/second)
GYRO_RANGE=2000


# ================================================================
# SYSTEM BEHAVIOR
# ================================================================

# Enable Debug Mode (verbose serial output)
DEBUG_MODE=true

# Enable Cloud Sync
CLOUD_SYNC_ENABLED=true

# Enable SMS Alerts
SMS_ALERTS_ENABLED=true

# Enable Overspeed Warning
OVERSPEED_WARNING_ENABLED=true

# Enable GPS Tracking
GPS_TRACKING_ENABLED=true

# Auto-Reset After Accident
AUTO_RESET_ENABLED=true


# ================================================================
# ADVANCED CONFIGURATION
# ================================================================

# WiFi Connection Attempts
WIFI_CONNECT_ATTEMPTS=20

# WiFi Reconnect Interval (milliseconds)
WIFI_RECONNECT_INTERVAL=60000

# DNS Server Port (Captive Portal)
DNS_SERVER_PORT=53

# Web Server Port
WEB_SERVER_PORT=80

# Serial Baud Rate (Debug)
SERIAL_BAUD_RATE=115200

# GPS Buffer Max Size (bytes)
GPS_BUFFER_MAX_SIZE=1000

# HTTP Request Timeout (milliseconds)
HTTP_TIMEOUT=10000


# ================================================================
# SAFETY & COMPLIANCE
# ================================================================

# Device Firmware Version
FIRMWARE_VERSION=3.0.0

# Device Manufacturer
MANUFACTURER=L-Guard Systems

# Certification/Compliance Codes
# CERTIFICATION=CE,FCC,RoHS

# Data Privacy Mode
# Options: FULL, ANONYMOUS, MINIMAL
PRIVACY_MODE=FULL

# Data Retention Period (days)
DATA_RETENTION_DAYS=90


# ================================================================
# NOTIFICATION TEMPLATES
# ================================================================

# SMS Template Variables:
# {DEVICE_ID} {TIME} {LAT} {LON} {SPEED} {ACCIDENT_TYPE}

SMS_ACCIDENT_TEMPLATE="🚨 VEHICLE ACCIDENT DETECTED! 🚨\nTime: {TIME} UTC\nDevice: {DEVICE_ID}\nLocation:\nLat: {LAT}\nLon: {LON}\nSpeed: {SPEED} km/h\nMap: https://maps.google.com/?q={LAT},{LON}\n⚠️ EMERGENCY ASSISTANCE NEEDED ⚠️"

SMS_OVERSPEED_TEMPLATE="⚠️ OVERSPEED ALERT\nDevice: {DEVICE_ID}\nSpeed: {SPEED} km/h\nDuration: {DURATION}s\nLocation: https://maps.google.com/?q={LAT},{LON}"


# ================================================================
# NOTES & INSTRUCTIONS
# ================================================================

# 1. ARDUINO/ESP32 USAGE:
#    - Copy values to your .ino file constants
#    - Update in code: const char* supabaseUrl = "YOUR_VALUE";
#
# 2. WEB DASHBOARD USAGE:
#    - Rename this file to .env
#    - Place in project root directory
#    - Use process.env.SUPABASE_URL in your code
#
# 3. SECURITY:
#    - NEVER commit this file to public repositories
#    - Add .env to .gitignore
#    - Use environment-specific files (.env.production, .env.development)
#
# 4. TESTING:
#    - Create .env.test with test credentials
#    - Use lower thresholds for easier testing
#
# 5. PRODUCTION:
#    - Use strong AP_PASSWORD (min 8 characters)
#    - Verify EMERGENCY_PHONE is correct
#    - Test SMS delivery before deployment
#    - Enable Row-Level Security in Supabase

# ================================================================
# END OF CONFIGURATION
# ================================================================